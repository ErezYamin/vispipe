# Copy this file to .env before running: cp .env.example .env
# Note: MINIO_ACCESS_KEY/SECRET_KEY here must match MINIO_ROOT_USER/PASSWORD in docker-compose.yml

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
DATABASE_URL=postgresql://vispipe:vispipe@localhost:5432/vispipe
POLL_INTERVAL=5
